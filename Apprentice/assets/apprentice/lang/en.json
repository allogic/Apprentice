  "item-mastersurveykit": "Master Survey Kit",
  "itemdesc-mastersurveykit": "A durable Grandmaster instrument for condensed prospecting reports. Requires the Miner Grandmaster skill to craft.",
  "block-joinersbench": "Joiner's Bench",
  "blockdesc-joinersbench": "A Woodworker Grandmaster station for precision joinery. Requires the Woodworker Grandmaster skill to craft.",
  "item-graftingkit": "Tool Upgrade Kit",
  "itemdesc-graftingkit": "Permanently raises a tool's maximum durability by 20%. Each tool can be upgraded once. Requires the Farmer Grandmaster skill to craft.",
  "block-architectstable": "Architect's Table",
  "blockdesc-architectstable": "A Builder Grandmaster station for structural templates. Requires the Builder Grandmaster skill to craft.",
  "item-masterforgeplans": "Legacy Master Forge Plans",
  "itemdesc-masterforgeplans": "A migration item retained for existing saves. Blacksmith authorization now comes directly from the Grandmaster skill.",
  "item-mastercookbook": "Master Cookware Set",
  "itemdesc-mastercookbook": "A durable utensil set for complete meals and preserved rations. Requires the Cook Grandmaster skill to craft.",
  "block-masterkiln": "Master Kiln",
  "blockdesc-masterkiln": "A Potter Grandmaster station for refractory components. Requires the Potter Grandmaster skill to craft.",
  "block-saddlersbench": "Saddler's Bench",
  "blockdesc-saddlersbench": "A Leatherworker Grandmaster station for harness and armor fittings. Requires the Leatherworker Grandmaster skill to craft.",
  "item-sewingkit": "Master Sewing Kit",
  "itemdesc-sewingkit": "A durable kit for liners, padded clothing and repairs. Requires the Tailor Grandmaster skill to craft.",
  "item-advancedtrapkit": "Bear Trap",
  "itemdesc-advancedtrapkit": "A recoverable bear trap. A triggered trap takes five seconds to rearm. Requires the Hunter Grandmaster skill to craft.",
  "item-masterweaponpatterns": "Weapon Upgrade Kit",
  "itemdesc-masterweaponpatterns": "Permanently raises a weapon's maximum durability by 20%. Each weapon can be upgraded once. Requires the Warrior Grandmaster skill to craft.",
  "item-compositebow": "Composite Bow",
  "itemdesc-compositebow": "A repairable Ranger Grandmaster bow. Requires the Ranger Grandmaster skill to craft.",
  "item-masterfishingrod": "Master Fishing Rod",
  "itemdesc-masterfishingrod": "A repairable Fisher Grandmaster rod. Requires the Fisher Grandmaster skill to craft.",
  "item-veterinarykit": "First Aid Kit",
  "itemdesc-veterinarykit": "Heals any injured living entity. Requires the Animal Husbandry Grandmaster skill to craft.",
  "block-framehive": "Frame Hive",
  "blockdesc-framehive": "A Beekeeper Grandmaster hive with removable-frame construction. Requires the Beekeeper Grandmaster skill to craft.",
