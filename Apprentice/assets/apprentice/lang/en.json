{
  "apprentice": "Apprentice",

  "game:characterclass-apprentice-race-dragonborn": "Dragonborn",
  "game:characterdesc-apprentice-race-dragonborn": "<font color=\"#e8bd79\"><i>Draconic blood lends strength, resilience, and a demanding metabolism.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +2 health, +8% melee damage.<br><font color=\"#ff8484\">Cons:</font> +15% hunger rate, -3% movement speed.",
  "game:characterclass-apprentice-race-dwarf": "Dwarf",
  "game:characterdesc-apprentice-race-dwarf": "<font color=\"#e8bd79\"><i>Stone-born endurance and forge tradition make dwarves exceptional underground workers.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +2 health, +12% mining speed, +8% ore yield, reduced armor slowdown.<br><font color=\"#ff8484\">Cons:</font> -8% movement speed, +8% hunger rate.",
  "game:characterclass-apprentice-race-elf": "Elf",
  "game:characterdesc-apprentice-race-elf": "<font color=\"#e8bd79\"><i>Keen senses and light-footed grace favor forests and ranged combat.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +12% ranged accuracy, +10% forage yield, +6% movement speed.<br><font color=\"#ff8484\">Cons:</font> -2 health, -8% melee damage.",
  "game:characterclass-apprentice-race-gnome": "Gnome",
  "game:characterdesc-apprentice-race-gnome": "<font color=\"#e8bd79\"><i>Inventive underground folk who answer danger with mechanisms and cunning.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +15% mechanical damage, +10% rusty-gear yield, lower temporal repair cost.<br><font color=\"#ff8484\">Cons:</font> -2 health, -12% melee damage.",
  "game:characterclass-apprentice-race-goliath": "Goliath",
  "game:characterdesc-apprentice-race-goliath": "<font color=\"#e8bd79\"><i>Giant ancestry grants a powerful frame built to endure harsh heights.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +3 health, +12% melee damage, reduced armor slowdown.<br><font color=\"#ff8484\">Cons:</font> +20% hunger rate, -8% ranged accuracy.",
  "game:characterclass-apprentice-race-halfling": "Halfling",
  "game:characterdesc-apprentice-race-halfling": "<font color=\"#e8bd79\"><i>Small, fortunate, and difficult to notice, halflings thrive through caution and luck.</i></font><br><br><font color=\"#84ff84\">Pros:</font> reduced animal detection, +10% forage yield, +8% vessel-loot chance.<br><font color=\"#ff8484\">Cons:</font> -2 health, -12% melee damage.",
  "game:characterclass-apprentice-race-human": "Human",
  "game:characterdesc-apprentice-race-human": "<font color=\"#e8bd79\"><i>Ambitious and adaptable, humans improve many disciplines without mastering one by birth.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +4% foraging, mining, melee, ranged, and mechanical output.<br><font color=\"#ff8484\">Cons:</font> +5% hunger rate and no specialized resistance.",
  "game:characterclass-apprentice-race-orc": "Orc",
  "game:characterdesc-apprentice-race-orc": "<font color=\"#e8bd79\"><i>Endurance, determination, and sudden speed carry orcs through brutal encounters.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +3 health, +12% melee damage, +5% movement speed.<br><font color=\"#ff8484\">Cons:</font> +20% hunger rate, -8% ranged accuracy.",
  "game:characterclass-apprentice-race-tiefling": "Tiefling",
  "game:characterdesc-apprentice-race-tiefling": "<font color=\"#e8bd79\"><i>A fiendish legacy brings otherworldly power while unsettling ordinary creatures.</i></font><br><br><font color=\"#84ff84\">Pros:</font> +1 health, +6% ranged damage, lower temporal repair cost.<br><font color=\"#ff8484\">Cons:</font> animals detect you from farther away, +8% hunger rate.",

